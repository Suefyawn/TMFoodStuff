# ============================================
# TMFoodStuff — Comprehensive .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Build outputs
dist/
build/
.next/
out/
.sanity/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Keep .env.example files (they're templates, not secrets)
!.env.example

# Next.js
.next/
next-env.d.ts

# Medusa
medusa-db.sql
uploads/

# Sanity
.sanity/
dist/

# TypeScript
*.tsbuildinfo

# Testing
coverage/
.nyc_output

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# OS files — Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# OS files — macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# Debug
.pnpm-debug.log*

# Vercel
.vercel

# Cloudinary / upload temp
public/uploads/
temp/

# Database
*.sqlite
*.db
