{
  "name": "tmfoodstuff-backend",
  "version": "0.0.1",
  "description": "TMFoodStuff Medusa.js backend",
  "main": "dist/main.js",
  "scripts": {
    "clean": "cross-env rimraf dist",
    "build": "cross-env npm run clean && tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/main.js",
    "seed": "medusa seed -f ./data/seed.json",
    "dev": "cross-env npm run build && medusa develop"
  },
  "dependencies": {
    "@medusajs/medusa": "^1.20.0",
    "medusa-fulfillment-manual": "^1.1.40",
    "medusa-payment-manual": "^1.0.24",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17",
    "cross-env": "^7.0.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.3",
    "@babel/core": "^7.14.3",
    "rimraf": "^3.0.2",
    "typescript": "^5.1.3"
  }
}
