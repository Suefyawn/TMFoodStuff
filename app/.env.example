# Supabase (primary database + storefront admin dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key
# Service role key — server-side only, bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Password for the /dashboard admin UI (server-side check only).
# Pick a long random value in production and rotate regularly.
DASHBOARD_PASSWORD=change-me-in-production

# Public site URL (used for metadata, canonical URLs, etc.)
NEXT_PUBLIC_SERVER_URL=https://tm-food-stuff.vercel.app

# Payload CMS / MongoDB (optional — only required if you want to use the
# /admin route at runtime. The Supabase-backed dashboard at /dashboard does
# not need MongoDB.)
MONGODB_URI=
PAYLOAD_SECRET=
