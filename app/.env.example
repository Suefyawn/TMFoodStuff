# ─────────────────────────────────────────────────────────────
# Supabase (primary database + storefront admin dashboard)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key
# Service role key — server-side only, bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# Admin dashboard auth
# ─────────────────────────────────────────────────────────────
# The /dashboard now uses Supabase Auth (one login per staff member).
# There is no password env var. To grant access:
#   1. Supabase → Authentication → Providers → Email → turn OFF public sign-ups.
#   2. Supabase → Authentication → Users → Add user (one per staff member).
#   3. Add each user's email to the `admin_users` table.

# ─────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────
# Public site URL — used for metadata, canonical URLs, sitemap,
# robots.txt and links in transactional emails.
NEXT_PUBLIC_SITE_URL=https://tmfoodstuff.ae

# Store contact info (used in footer, contact page, account page, and order notifications)
NEXT_PUBLIC_WHATSAPP_NUMBER=971544408411
NEXT_PUBLIC_STORE_EMAIL=hello@tmfoodstuff.ae

# Launch promotion — promo code shown in the banner
# Add this code to the promo_codes table in Supabase to make it work
NEXT_PUBLIC_PROMO_CODE=FRESH10

# ─────────────────────────────────────────────────────────────
# Delivery settings
# ─────────────────────────────────────────────────────────────
# Set NEXT_PUBLIC_LAUNCH_FREE_DELIVERY=false to end the free-delivery launch period
NEXT_PUBLIC_LAUNCH_FREE_DELIVERY=true
# Only used when launch free delivery is false:
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD=150
NEXT_PUBLIC_DELIVERY_FEE=15

# ─────────────────────────────────────────────────────────────
# Email — Resend (optional; emails are silently skipped if unset)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@tmfoodstuff.ae
ADMIN_EMAIL=orders@tmfoodstuff.ae

# ─────────────────────────────────────────────────────────────
# Error tracking — Sentry (optional; disabled if DSN unset)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─────────────────────────────────────────────────────────────
# Analytics — PostHog (optional; disabled if key unset)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────────────────────
# Payments — Stripe (optional; the "Pay Online" option is hidden
# at checkout when STRIPE_SECRET_KEY is unset — cash on delivery
# always works)
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From the Stripe dashboard webhook endpoint (events: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=
