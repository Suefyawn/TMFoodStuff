# Supabase (primary database + storefront admin dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key
# Service role key — server-side only, bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Password for the /dashboard admin UI (server-side check only).
# Pick a long random value in production and rotate regularly.
DASHBOARD_PASSWORD=change-me-in-production

# Public site URL (used for metadata, canonical URLs, etc.)
NEXT_PUBLIC_SERVER_URL=https://tm-food-stuff.vercel.app

# Store contact info (used in footer, contact page, account page, and order notifications)
NEXT_PUBLIC_WHATSAPP_NUMBER=971544408411
NEXT_PUBLIC_STORE_EMAIL=hello@tmfoodstuff.ae

# Launch promotion — promo code shown in the banner
# Add this code to the promo_codes table in Supabase to make it work
NEXT_PUBLIC_PROMO_CODE=FRESH10

# Delivery settings
# Set NEXT_PUBLIC_LAUNCH_FREE_DELIVERY=false to end the free-delivery launch period
NEXT_PUBLIC_LAUNCH_FREE_DELIVERY=true
# Only used when launch free delivery is false:
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD=150
NEXT_PUBLIC_DELIVERY_FEE=15
